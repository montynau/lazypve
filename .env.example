# Copy to .env and fill in your Proxmox VE connection details.
# Create the API token under Datacenter -> Permissions -> API Tokens (PVEAuditor role is enough for read-only monitoring).

LAZYPVE_HOST=https://192.168.1.10:8006
LAZYPVE_TOKEN_ID=root@pam!lazypve
LAZYPVE_TOKEN_SECRET=00000000-0000-0000-0000-000000000000

# Proxmox uses a self-signed certificate by default; set to true unless you've installed a trusted cert.
LAZYPVE_INSECURE_SKIP_VERIFY=true

# Optional: give this cluster a name in the UI (defaults to "default").
# LAZYPVE_NAME=homelab

# Optional: monitor more than one cluster by using a numbered list instead of
# the unnumbered vars above. Add LAZYPVE_CLUSTER3_*, etc. for more.
# LAZYPVE_CLUSTER1_NAME=homelab
# LAZYPVE_CLUSTER1_HOST=https://192.168.1.10:8006
# LAZYPVE_CLUSTER1_TOKEN_ID=root@pam!lazypve
# LAZYPVE_CLUSTER1_TOKEN_SECRET=00000000-0000-0000-0000-000000000000
# LAZYPVE_CLUSTER1_INSECURE_SKIP_VERIFY=true
#
# LAZYPVE_CLUSTER2_NAME=work
# LAZYPVE_CLUSTER2_HOST=https://10.0.0.5:8006
# LAZYPVE_CLUSTER2_TOKEN_ID=root@pam!lazypve
# LAZYPVE_CLUSTER2_TOKEN_SECRET=00000000-0000-0000-0000-000000000000
# LAZYPVE_CLUSTER2_INSECURE_SKIP_VERIFY=true
